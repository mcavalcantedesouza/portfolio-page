{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "playwright.env": {
    "CI": "false"
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.angular": true,
    "**/dist": true,
    "**/test-results": true,
    "**/.git": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/test-results": true
  },
  "extensions.recommendations": [
    "esbenp.prettier-vscode",
    "ms-playwright.playwright",
    "angular.ng-template"
  ],
  "typescript.tsserver.projectMatcherIgnoreList": ["**/node_modules"],
  "[playwrightvscode]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
